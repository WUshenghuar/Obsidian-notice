		{"id":"n005500000000000","type":"text","text":"❌ 矩阵式不是WBS表达形式","x":1900,"y":395,"width":540,"height":25},
		{"id":"n012700000000000","type":"text","text":"❌ 所有变更需CCB批准 → ✅ 部分PM可定","x":700,"y":1150,"width":580,"height":25},
		{"id":"n012800000000000","type":"text","text":"❌ WBS最低层=分到个人 → ✅ **工作包**","x":700,"y":1180,"width":580,"height":25},
