      "type": "text",
      "x": 1340,
      "y": 555,
      "width": 500,
      "height": 25,
      "text": "**质量成本 = 预防成本 + 缺陷成本**"
    },
    {
      "id": "n008600000000000",
      "type": "text",
      "x": 1340,
      "y": 590,
      "width": 500,
      "height": 30,
      "text": "## 两大过程",
